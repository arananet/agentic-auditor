# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAACo07B70a2WlqXNQ
TURNSTILE_SECRET_KEY=your_secret_key_here

# Cloudflare Workers AI (optional) — enables the deep semantic / LLM analysis.
# When unset, the auditor falls back to heuristic-only scoring.
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# Agent Memory Layer (optional) — durable store for longitudinal score history
# and feedback. Defaults to <cwd>/.memory. On Railway, point this at a mounted
# volume for cross-deploy durability; if unwritable, memory runs in-process only.
MEMORY_DB_PATH=.memory
